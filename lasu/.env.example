# Copy these into Render's dashboard under your Web Service > Environment.
# Do NOT put real values in this file or commit a .env file to Git.

# Database (from your Render MySQL / external MySQL provider)
DB_HOST=
DB_PORT=3306
DB_NAME=lasu_health_center
DB_USER=
DB_PASS=

# Gmail SMTP (myaccount.google.com > Security > App Passwords)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
SENDER_NAME=LASU Health Center

# Termii SMS API (termii.com dashboard)
TERMII_API_KEY=
TERMII_SENDER_ID=LASUHealth
